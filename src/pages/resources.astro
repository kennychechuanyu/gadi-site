---
import PageLayout from "../layouts/PageLayout.astro";
import Section from "../components/Section.astro";
---

<PageLayout
  title="Resources — GADI"
  description="A curated collection of resources on generalization research across disciplines. Coming soon."
  pageTitle="Resources"
  pageSubtitle="Curated readings and tools"
>
  <Section background="white">
    <div class="max-w-xl fade-up">
      <div class="px-10 py-14 text-center bg-cream-50">
        <p class="label-caps mb-2 text-stone-400">Coming Soon</p>
        <p class="text-sm font-body text-stone-400 max-w-sm mx-auto leading-relaxed">
          This page will host a curated collection of papers, books, datasets, and tools relevant
          to generalization research. Resources will be added as the network develops.
        </p>
      </div>
      <p class="mt-6 text-sm font-body text-stone-500 leading-relaxed">
        If you have a suggestion, feel free to reach out via the <a href="/contact" class="text-indigo-600 hover:underline">contact page</a>.
      </p>
    </div>
  </Section>
</PageLayout>
