---
import PageLayout from "../../layouts/PageLayout.astro";
import Section from "../../components/Section.astro";
---

<PageLayout
  title="News — GADI"
  description="Meeting notes, announcements, and updates from the Generalization Across Domains Initiative."
  pageTitle="News"
  pageSubtitle="Network updates"
>
  <Section background="white">
    <div class="max-w-xl fade-up">
      <div class="px-10 py-14 text-center bg-cream-50">
        <p class="label-caps mb-2 text-stone-400">Coming Soon</p>
        <p class="text-sm font-body text-stone-400 max-w-sm mx-auto leading-relaxed">
          News, meeting notes, and announcements from the network will be posted here as the
          initiative develops. Check back soon.
        </p>
      </div>
    </div>
  </Section>
</PageLayout>
