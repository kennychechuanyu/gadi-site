---
interface Props {
  title: string;
  date: Date;
  endDate?: Date;
  location: string;
  type: "conference" | "workshop" | "hackathon" | "summer-school" | "expert-meeting" | "webinar";
  href?: string;
  featured?: boolean;
}

const { title, date, endDate, location, type, href, featured = false } = Astro.props;

const typeLabels: Record<string, string> = {
  "conference":    "Conference",
  "workshop":      "Workshop",
  "hackathon":     "Hackathon",
  "summer-school": "Summer School",
  "expert-meeting":"Expert Meeting",
  "webinar":       "Webinar",
};

const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class:list={[
    "group flex flex-col border bg-white transition-all duration-200",
    featured ? "border-indigo-400" : "border-cream-300",
    href && "hover:border-indigo-400 hover:shadow-sm cursor-pointer",
  ]}
>
  <!-- Date block -->
  <div class:list={[
    "flex items-center gap-4 border-b px-5 py-4",
    featured ? "border-indigo-200 bg-indigo-50" : "border-cream-200 bg-cream-50",
  ]}>
    <div class="flex-shrink-0 text-center">
      <div class="font-display text-3xl font-bold leading-none text-ink-900">
        {date.getDate()}
      </div>
      <div class="label-caps mt-0.5 text-stone-500">
        {months[date.getMonth()]} {date.getFullYear()}
      </div>
    </div>
    {endDate && (
      <>
        <div class="h-px flex-1 bg-cream-300" />
        <div class="flex-shrink-0 text-center">
          <div class="font-display text-3xl font-bold leading-none text-ink-900">
            {endDate.getDate()}
          </div>
          <div class="label-caps mt-0.5 text-stone-500">
            {months[endDate.getMonth()]} {endDate.getFullYear()}
          </div>
        </div>
      </>
    )}
  </div>

  <!-- Content -->
  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-center justify-between gap-2 mb-3">
      <span class="label-caps text-indigo-600">{typeLabels[type]}</span>
      {featured && (
        <span class="label-caps text-indigo-500">Featured</span>
      )}
    </div>
    <h3 class="font-display text-xl font-semibold text-ink-900 leading-snug group-hover:text-indigo-700 transition-colors">
      {title}
    </h3>
    <div class="mt-3 flex items-center gap-1.5 text-xs font-body text-stone-500">
      <svg class="h-3.5 w-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
      </svg>
      {location}
    </div>
  </div>
</Tag>
