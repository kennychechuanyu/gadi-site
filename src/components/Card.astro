---
interface Props {
  title: string;
  description: string;
  number?: string;
  href?: string;
  class?: string;
}

const { title, description, number, href, class: extraClass = "" } = Astro.props;

const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class:list={[
    "group block border border-cream-300 bg-white p-7 transition-all duration-200",
    href && "hover:border-indigo-400 hover:shadow-sm cursor-pointer",
    extraClass,
  ]}
>
  {number && (
    <div class="mb-5 font-display text-4xl font-bold text-indigo-400 leading-none">
      {number}
    </div>
  )}
  <slot name="icon" />
  <h3 class="font-display text-xl font-semibold text-ink-900 group-hover:text-indigo-700 transition-colors">
    {title}
  </h3>
  <p class="mt-3 text-sm font-body leading-relaxed text-stone-600">
    {description}
  </p>
  <slot />
</Tag>
