---
interface Props {
  name: string;
  title: string;
  institution: string;
  department?: string;
  country: string;
  email: string;
  role: "coordinator" | "steering" | "member";
  photo?: string;
  bio?: string;
}

const { name, title, institution, department, country, email, photo, bio, role } = Astro.props;

const initials = name
  .split(" ")
  .map((n) => n[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();
---

<article class="group relative flex flex-col items-center pt-8 text-center">
  <!-- Top accent rule — animates on hover -->
  <div aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-cream-300" />
  <div aria-hidden="true" class="absolute inset-x-0 top-0 h-[2px] w-0 bg-indigo-500 transition-[width] duration-700 ease-out group-hover:w-full" />

  <!-- Photo / Initials -->
  {photo ? (
    <img
      src={photo}
      alt={name}
      class="h-32 w-32 rounded-full object-cover object-top ring-2 ring-cream-200 transition-all duration-300 group-hover:ring-indigo-300"
    />
  ) : (
    <div class="flex h-32 w-32 rounded-full items-center justify-center bg-cream-100 ring-2 ring-cream-200 transition-all duration-300 group-hover:ring-indigo-300">
      <span class="font-display text-3xl font-semibold text-indigo-400 select-none">
        {initials}
      </span>
    </div>
  )}

  <!-- Info block -->
  <div class="mt-5 space-y-1">
    <h3 class="font-display text-lg font-semibold text-ink-900 leading-snug">
      {name}
    </h3>
    <p class="text-sm font-medium text-indigo-600">{institution}</p>
    {department && (
      <p class="text-xs font-body text-stone-500">{department}</p>
    )}
  </div>

  <!-- Divider + Bio + Email zone -->
  <div class="mt-5 w-full border-t border-cream-200 pt-4">
    {bio ? (
      <details class="bio-accordion">
        <summary class="cursor-pointer select-none text-center font-body text-[11px] font-medium uppercase text-stone-400 transition-colors hover:text-indigo-600" style="letter-spacing: 0.18em;">
          <span class="bio-toggle-label">About</span>
        </summary>
        <div class="bio-content">
          <div class="overflow-hidden">
            <p class="mt-4 px-2 text-[13px] font-body leading-[1.75] text-stone-500 text-justify">
              {bio}
            </p>
          </div>
        </div>
      </details>
    ) : null}

    <!-- Email — always at the bottom -->
    <a
      href={`mailto:${email}`}
      class:list={[
        "block text-center text-stone-400 transition-colors hover:text-amber-600",
        bio ? "mt-4 border-t border-cream-200 pt-3" : "",
      ]}
      style="font-family: 'JetBrains Mono', monospace; font-size: 11px;"
    >
      {email}
    </a>
  </div>
</article>
